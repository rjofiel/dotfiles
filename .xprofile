#!/bin/bash
# ~/.xprofile - executed by SDDM/LightDM on login

# Env vars
export PATH=$HOME/.local/bin:$PATH
export _JAVA_AWT_WM_NONREPARENTING=1
export QT_STYLE_OVERRIDE=kvantum 
export EDITOR=antigravity
export XDG_CURRENT_DESKTOP=Qtile
export XDG_SESSION_TYPE=x11

# Wait for X to be ready
sleep 1

# Screens (commented out - verify before enabling)
# hdmi=$(xrandr | grep ' connected' | grep 'HDMI' | awk '{print $1}')
# if [ "$hdmi" = "HDMI-1" ]; then
#   xrandr --output eDP-1 --primary --mode 1366x768 --pos 276x1080 --output HDMI-1 --mode 1920x1080 --pos 0x0 &
# else
#   xrandr --output eDP-1 --primary --mode 1366x768 --pos 0x0 --rotate normal --output HDMI-1 --off --output DP-1 --off &
# fi

# Start services in background with error handling
(

    # Network Manager - with retry logic
    for i in 1 2 3; do
        if command -v nm-applet &>/dev/null; then
            nm-applet --indicator &>/dev/null &
            break
        fi
        sleep 1
    done

    # Automount Devices
    if command -v udiskie &>/dev/null; then
        udiskie -t &
    fi

) &

# Run XDG autostart apps (optional)
# if command -v dex &>/dev/null; then
#     dex --autostart --environment Qtile &
# fi
